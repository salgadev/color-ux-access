# Local environment variables for color-ux-access
# Copy this to .env and fill in your values (do not commit .env to version control)

# HF Token for VLM inference via HuggingFace Router
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Optional: Local llama.cpp server URL (for offline fallback)
LLAMA_SERVER_URL=http://localhost:8080/v1

# Optional: Modal profile to use (default: narwall-tech)
MODAL_PROFILE=narwall-tech